# Bankr API key (recommended: Bankr-only launches, no RPC needed)
# Get from bankr.bot/api. For /deploy: key must have Agent API (write) access enabled.
# Required for hot-ping correct CA (re-fetch by token address) and for single-launch/watch details.
BANKR_API_KEY=your_bankr_api_key_here

# Optional: handle -> wallet when API doesn't return them (JSON or "handle:0x...,other:0x...")
# BANKR_HANDLE_WALLET_OVERRIDES={"gork":"0x23c468c3dfb72fa31f448d9d86f901ccf829338a"}

# Base RPC URL — required for claimable fees (on-chain). Only this variable is used; set it on Railway.
# Without it, the bot cannot show claimable amounts or claim status. Public: https://mainnet.base.org or https://base.publicnode.com
RPC_URL_BASE=https://mainnet.base.org

# Doppler indexer (GraphQL at /graphql). Bankr indexer default: https://bankr.indexer.doppler.lol
# Override with your endpoint if different (e.g. self-hosted doppler-indexer on Railway).
# Fees: pools(where: { baseToken }), then cumulatedFees(poolId, chainId, beneficiary).
DOPPLER_INDEXER_URL=https://bankr.indexer.doppler.lol

# Filter indexer tokens by this integration/beneficiary address (Bankr: only tokens that have this as fee recipient).
# Used only when fetching the new-token feed in notify (so you only see Bankr tokens). Not used for /fees-token — fee recipient display uses the launch's actual fee recipient wallet.
# If your indexer uses a different integration address for the feed, set it here.
BANKR_INTEGRATION_ADDRESS=0xF60633D02690e2A15A54AB919925F3d038Df163e

CHAIN_ID=8453

# Discord: channel IDs are usually set per server via /setup (each server can have different channels).
# Optional env fallbacks (leave blank to use only /setup):
# DISCORD_ALL_LAUNCHES_CHANNEL_ID=   # Firehose: every Bankr deploy (no filters)
# DISCORD_ALERT_CHANNEL_ID=          # Curated: only passes FILTER_X_MATCH / FILTER_MAX_DEPLOYS
# DISCORD_WATCH_ALERT_CHANNEL_ID=    # Watch list only
# DISCORD_HOT_LAUNCH_ALERT_CHANNEL_ID=  # Hot tokens (5+ buys in 1 min, 20+ holders). Optional.
# HOT_LAUNCH_ENABLED=true             # Set to false to disable hot token alerts (default: true)
# DISCORD_TRENDING_ALERT_CHANNEL_ID=  # Trending token alerts. Optional.
# TRENDING_ENABLED=false              # Set to true to enable trending alerts (default: false)
# TRENDING_MIN_BUYS_5M=15             # Min buys in 5m to post to trending channel/topic (default 15; 0=off)
# TRENDING_MIN_BUYS_1H=30            # Min buys in 1h to post to trending (default 30; 0=off)

# Or use webhook (only when no Discord channel IDs are set)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: debug webhook — errors and activity (lookups, fees, paste, deploy, watch/claim-watch list). On ready, sends server + Telegram counts.
# DISCORD_DEBUG_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram firehose: every new Bankr deployment is sent to this chat (same idea as Discord firehose).
# Create a bot with @BotFather, add it to a group/channel, then set:
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=-1001234567890
# Get chat ID: message @userinfobot in the chat, or use getUpdates after the bot receives a message.
# Per-server Telegram is set in /setup (tenant.telegramChatId); this env is the global firehose.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Notify loop: ms between polls (default 60000 = 1 min; use 30000 for 30 sec)
# POLL_INTERVAL_MS=60000

# Watch list: only notify when deployer matches (overrides FILTER_X_MATCH)
# WATCH_X_USERS=thryxagi,crewdegen
# WATCH_FC_USERS=dwr.eth,vitalik.eth
# WATCH_WALLETS=0x1234...,0x5678...
# WATCH_KEYWORDS=pepe,btc,sol,"this is a test"

# Optional: path for seen-tokens persistence (use a volume path so it survives deploys)
# SEEN_FILE=/data/bankr-seen.json

# Per-server config from /setup and /settings (multi-tenant).
# On Railway: add a volume (e.g. mount path /data) and set the path below so settings survive redeploys.
# TENANTS_FILE=/data/bankr-tenants.json

# Optional: cap seen list size (e.g. 3000) to avoid unbounded growth; if unset, seen list is unbounded and tokens are never re-pinged.
# SEEN_MAX_KEYS=3000

# Optional: Agent Profiles — bot polls bankr.bot/agent-profiles and alerts when a new approved agent is added.
# SEEN_AGENTS_FILE=/data/bankr-seen-agents.json
# Optional: get Discord pings when these agents update (slug list, comma-separated). New agents always get one alert.
# WATCHED_AGENT_SLUGS=clanker,truth_terminal
# Optional: set to 1 to log raw API response shape (debug only).
# AGENT_PROFILES_DEBUG=1
