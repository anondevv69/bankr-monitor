# Copy to `.env` and fill in secrets. Do not commit `.env` or real tokens (see SECURITY.md).
#
# Optional: product name + repo URL (Discord/Telegram copy and Bankr API User-Agent). Default display name: BankrMonitor Personal.
# BRAND_DISPLAY_NAME=My Bankr Bot
# BRAND_REPO_URL=https://github.com/yourusername/your-repo
#
# Bankr API key (recommended: Bankr-only launches, no RPC needed)
# Get from bankr.bot/api. For /deploy: key must have Agent API (write) access enabled.
# Required for hot-ping correct CA (re-fetch by token address) and for single-launch/watch details.
BANKR_API_KEY=your_bankr_api_key_here
# Telegram only: extra Bankr keys for DM + group lookups (comma or newline). Round-robin; BANKR_API_KEY above is always tried too (deduped).
# TELEGRAM_BANKR_API_KEYS=key_from_portal_1,key_from_portal_2
# Optional: cache TTL (ms) for wallet deploy/fee-recipient counts on Bankr (Discord embeds). Default 300000 (5m).
# BANKR_WALLET_ROLE_COUNT_TTL_MS=300000

# Optional: handle -> wallet when API doesn't return them (JSON or "handle:0x...,other:0x...")
# BANKR_HANDLE_WALLET_OVERRIDES={"example_handle":"0x1111111111111111111111111111111111111111"}

# Base RPC URL — required for claimable fees (on-chain). Only this variable is used; set it on Railway.
# Without it, the bot cannot show claimable amounts or claim status. Public: https://mainnet.base.org or https://base.publicnode.com
RPC_URL_BASE=https://mainnet.base.org

# Optional: BaseScan API key for claim detection fallback (when RPC/indexer miss claim events).
# Get one at https://basescan.org/apis — improves rate limits when checking "fee recipient has claimed".
# BASESCAN_API_KEY=your_basescan_api_key

# Doppler indexer (GraphQL at /graphql). Bankr indexer default: https://bankr.indexer.doppler.lol
# Override with your endpoint if different (e.g. self-hosted doppler-indexer on Railway).
# Fees: pools(where: { baseToken }), then cumulatedFees(poolId, chainId, beneficiary).
DOPPLER_INDEXER_URL=https://bankr.indexer.doppler.lol

# Cashtag resolution ($TICKER → 0x…ba3): indexer GraphQL symbol search, Bankr suffix filter, pick highest mcap.
# CASHTAG_RESOLVE_TTL_MS=45000
# CASHTAG_MIN_LIQUIDITY_USD=20000
# CASHTAG_MIN_VOLUME24_USD=50000
# CASHTAG_SYMBOL_QUERY_LIMIT=200
# CASHTAG_MAX_CANDIDATES=50
# CASHTAG_DEX_FETCH_CONCURRENCY=6

# Filter indexer tokens by this integration/beneficiary address (Bankr: only tokens that have this as fee recipient).
# Used only when fetching the new-token feed in notify (so you only see Bankr tokens). Not used for /fees-token — fee recipient display uses the launch's actual fee recipient wallet.
# If your indexer uses a different integration address for the feed, set it here.
BANKR_INTEGRATION_ADDRESS=0xF60633D02690e2A15A54AB919925F3d038Df163e

CHAIN_ID=8453

# Discord: hide /deploy slash command (e.g. public bot instance). Default: /deploy is registered for self-hosters.
# HIDE_DEPLOY_COMMAND=true

# Discord: channel IDs are usually set per server via /setup (each server can have different channels).
# Optional env fallbacks (leave blank to use only /setup):
# DISCORD_ALL_LAUNCHES_CHANNEL_ID=   # Firehose: every Bankr deploy (no filters)
# DISCORD_ALERT_CHANNEL_ID=          # Curated: only passes FILTER_X_MATCH / FILTER_MAX_DEPLOYS
# DISCORD_WATCH_ALERT_CHANNEL_ID=    # Watch list only (also used for /activity-watch alerts; fallback: claims → curated → all launches)
# ACTIVITY_WATCH_POLL_MS=60000        # How often to check /activity-watch rules (default 60s, min 30s)
# DISCORD_HOT_LAUNCH_ALERT_CHANNEL_ID=  # Hot tokens (5+ buys in 1 min, 20+ holders). Optional.
# HOT_LAUNCH_ENABLED=true             # Set to false to disable hot token alerts (default: true)
# DISCORD_TRENDING_ALERT_CHANNEL_ID=  # Trending token alerts. Optional.
# TRENDING_ENABLED=true               # Explicit on/off. If unset, trending still posts when DISCORD_TRENDING_ALERT_CHANNEL_ID + TRENDING_MIN_* thresholds are set.
# TRENDING_MIN_BUYS_30M=20            # Min buys in ~30m for trending (DexScreener m30, else floor(1h/2); default 20; 0=off)
# TRENDING_MIN_BUYS_5M=0              # Optional extra: min buys in 5m (m5). Old default was 15 if you want that back.
# TRENDING_MIN_BUYS_1H=0             # Optional extra: min buys in 1h. Old default was 50.
# Restore legacy-only trending: TRENDING_MIN_BUYS_30M=0 TRENDING_MIN_BUYS_5M=15 TRENDING_MIN_BUYS_1H=50
# Optional: Doppler indexer volume thresholds (same GraphQL as bankr.indexer.doppler.lol). 0 = off.
# Pool ~1h vol = sum of last four 15m buckets; 24h vol = latest volumeBuckets24h row.
# HOT_LAUNCH_MIN_INDEXER_VOL_1H_USD=5000   # Example: hot ping if indexer ~1h volume ≥ $5k
# TRENDING_MIN_INDEXER_VOL_24H_USD=25000   # Example: trending if indexer 24h bucket volume ≥ $25k

# Real-time Doppler fee-claim firehose (Alchemy WebSocket). No polling; detects Transfer(from=feeLocker) instantly.
# ALCHEMY_KEY=your_alchemy_api_key     # Or ALCHEMY_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# DISCORD_CLAIM_FIREHOSE_CHANNEL_ID=   # Discord channel ID to post every fee claim (Bankr tokens only)
# DISCORD_CLAIM_TOKEN_CHANNELS=        # Optional: route claims for specific tokens to a channel. JSON: {"0x...ba3":"channelId",...}
# CLAIM_MIN_WETH=0.01                  # Only post claim alerts when WETH claimed is >= this (default 0.01; was 0.0001)
# BANKR_TOKEN_SUFFIX=ba3               # Bankr token CAs end with this; claim firehose + notify/hot/trending/indexer feed all require it (default ba3)
# Claim quiet window (EST): skip posting claim alerts during this hour to reduce pings and Alchemy load (e.g. 8–9pm EST).
# CLAIM_QUIET_START_EST=20             # Hour start (0–23, America/New_York). Set both to enable.
# CLAIM_QUIET_END_EST=21               # Hour end (exclusive). Example: 20–21 = 8pm–9pm EST.

# Or use webhook (only when no Discord channel IDs are set)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: debug webhook — errors and activity (lookups, fees, paste, deploy, watch/claim-watch list). On ready, sends server + Telegram counts.
# DISCORD_DEBUG_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram firehose: every new Bankr deployment is sent to this chat (same idea as Discord firehose).
# Create a bot with @BotFather, add it to a group/channel, then set:
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=-1001234567890
# Get chat ID: message @userinfobot in the chat, or use getUpdates after the bot receives a message.
# Per-server Telegram is set in /setup (tenant.telegramChatId); this env is the global firehose.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Claim alerts: post fee-claim messages to a Telegram chat (same as Discord claim firehose). Optional topic for forums.
# TELEGRAM_CLAIM_CHAT_ID=-1001234567890
# TELEGRAM_CLAIM_TOPIC_ID=2
# With TELEGRAM_BOT_TOKEN set, the bot answers /claims <wallet> in any group/DM. TELEGRAM_ALLOWED_CHAT_IDS only limits outbound launch/claim posts from notify.js — it does not block interactive commands in other groups.
# Delay Telegram (firehose, curated, claims, hot/trending) after Discord posts. Default 30000 ms. TELEGRAM_OUTBOUND_DELAY_MS overrides; falls back to TELEGRAM_HOT_PING_DELAY_MS.
# TELEGRAM_OUTBOUND_DELAY_MS=30000
# TELEGRAM_HOT_PING_DELAY_MS=30000
# Trade buttons (token cards): Sigma bot @username for ?start=xinfo-&lt;checksum&gt;. Default Sigma_buyBot. Do not set to "info" (reserved on Telegram — breaks links).
# TELEGRAM_SIGMA_BOT_USERNAME=Sigma_buyBot

# --- Telegram personal DMs (same bot token; private chat only; requires Discord bot process) ---
# Optional: extra Telegram-only keys (comma/newline). BANKR_API_KEY is always included as fallback for lookups.
# Optional: max token rows per /lookup DM reply (default 15).
# TELEGRAM_LOOKUP_MAX_ROWS=15
# TELEGRAM_BANKR_API_KEYS=bk_...,bk_...,bk_...
# TELEGRAM_PERSONAL_DMS_ENABLED=true
# Personal *hot/trending* DMs: delay after Discord (default = TELEGRAM_HOT_PING_DELAY_MS, 30000 ms).
# TELEGRAM_DM_DELAY_MS=30000
# Personal *watchlist launch + claim* DMs: default follows TELEGRAM_OUTBOUND_DELAY_MS / TELEGRAM_HOT_PING_DELAY_MS (30000 ms). Set 0 for immediate.
# TELEGRAM_DM_WATCHLIST_DELAY_MS=30000
# REQUIRED on Railway (or any ephemeral disk): persistent path or watchlists/settings reset every deploy.
# Default without this var: .telegram-personal-users.json in app cwd (wiped on redeploy).
# TELEGRAM_PERSONAL_USERS_FILE=/data/telegram-personal-users.json
# Optional: comma-separated Telegram user IDs allowed to use /start and receive DMs. If unset, any user can register.
# TELEGRAM_DM_ALLOWED_USER_IDS=123456789,987654321

# Telegram groups: per-group JSON (paste lookup, group watch list, hot/trending toggles, optional forum topic ids). Use a volume on Railway.
# TELEGRAM_GROUP_SETTINGS_FILE=/data/telegram-group-settings.json
# If TELEGRAM_ALLOWED_CHAT_IDS is set, add each group chat id so watch/hot/trending alerts can be posted there.

# Notify loop: ms between polls (default 60000 = 1 min; use 30000 for 30 sec)
# POLL_INTERVAL_MS=60000

# Watch list: only notify when deployer matches (overrides FILTER_X_MATCH)
# WATCH_X_USERS=thryxagi,crewdegen
# WATCH_FC_USERS=dwr.eth,vitalik.eth
# WATCH_WALLETS=0x1234...,0x5678...
# WATCH_KEYWORDS=pepe,btc,sol,"this is a test"

# Optional: path for seen-tokens persistence (use a volume path so it survives deploys)
# SEEN_FILE=/data/bankr-seen.json
# Optional: cumulative “deploys in feed” / “tokens as fee recipient in feed” (updated each notify poll)
# DEPLOY_COUNT_FILE=/data/bankr-deploy-counts.json
# FEE_RECIPIENT_COUNT_FILE=/data/bankr-fee-recipient-counts.json

# Per-server config from /setup and /settings (multi-tenant).
# On Railway: add a volume (e.g. mount path /data) and set the path below so settings survive redeploys.
# TENANTS_FILE=/data/bankr-tenants.json

# Optional: cap seen list size (e.g. 3000) to avoid unbounded growth; if unset, seen list is unbounded and tokens are never re-pinged.
# SEEN_MAX_KEYS=3000

# Optional: Agent Profiles — bot polls bankr.bot/agent-profiles and alerts when a new approved agent is added.
# SEEN_AGENTS_FILE=/data/bankr-seen-agents.json
# Optional: get Discord pings when these agents update (slug list, comma-separated). New agents always get one alert.
# WATCHED_AGENT_SLUGS=clanker,truth_terminal
# Optional: set to 1 to log raw API response shape (debug only).
# AGENT_PROFILES_DEBUG=1
